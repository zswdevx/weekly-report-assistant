{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "weekly-report-assistant",
  "version": "0.3.0",
  "identifier": "com.weekly-report-assistant.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "周报助手",
        "width": 900,
        "height": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/zswdevx/weekly-report-assistant/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI4NUM5QTM2QzExQTI4MkEKUldRcUtCckJOcHBjS0t2K2dQM0c3Z2YzN3BTRFBiaWxaR1hjUmoxakxBTHduVisxcXJtbkVsSkkK"
    }
  }
}
